{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "src/app/modal/modal.jsx",
    "src/app/api/v1/auth/route.ts",
    "src/app/api/v1/page.jsx",
    "src/test/api/auth/login.test.js",
    "vitest.config.mts",
    "src/lib/db/connectDB.ts",
    "src/app/calibration/torque/components/sevenSegments.tsx",
    "src/app/calibration/torque/page.jsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
, "public/sw.js"  ],
  "exclude": [
    "node_modules"
  ]
}
